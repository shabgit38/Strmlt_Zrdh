## Use badges instead of colored rows

```python
def action_badge(action):
    colors = {
        "Entry Candidate": ("#EAF7EF", "#176B3A"),
        "Waiting Trigger": ("#FFF7E6", "#8A5A00"),
        "Near Entry": ("#EEF4FF", "#2457A6"),
        "Wait": ("#F4F4F5", "#52525B"),
        "Avoid": ("#FDECEC", "#9F1D1D"),
    }
    bg, fg = colors.get(action, ("#F4F4F5", "#52525B"))
    return f"""
    <span style="
        background:{bg};
        color:{fg};
        padding:4px 9px;
        border-radius:999px;
        font-size:12px;
        font-weight:600;
    ">{action}</span>
    """
```

